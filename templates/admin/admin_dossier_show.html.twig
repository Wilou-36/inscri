{# templates/admin/dossier_show.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}Dossier #{{ dossier.id }} — {{ dossier.nom ?? 'Incomplet' }}{% endblock %}

{% block breadcrumb %}
<nav class="rf-breadcrumb" aria-label="Fil d'Ariane">
    <div class="rf-container">
        <ol>
            <li><a href="{{ path('admin_dashboard') }}">Administration</a></li>
            <li><a href="{{ path('admin_candidats') }}">Candidats</a></li>
            <li><span aria-current="page">
                {{ dossier.nom ? dossier.nom|upper ~ ' ' ~ dossier.prenom : 'Dossier #' ~ dossier.id }}
            </span></li>
        </ol>
    </div>
</nav>
{% endblock %}

{% block body %}

{# ── En-tête ── #}
<div class="rf-page-header">
    <div class="rf-container">
        <p class="rf-page-header__eyebrow">Administration · Lycée Fulbert</p>
        <h1>
            Dossier #{{ dossier.id }}
            — {{ dossier.nom ? dossier.nom|upper : '?' }} {{ dossier.prenom ?? '?' }}
        </h1>
        <p class="rf-page-header__sub">
            {{ dossier.user.email }}
            &nbsp;·&nbsp; Modifié le {{ dossier.updatedAt|date('d/m/Y à H:i') }}
            {% if dossier.soumisAt %}
                &nbsp;·&nbsp; Soumis le {{ dossier.soumisAt|date('d/m/Y à H:i') }}
            {% endif %}
        </p>
    </div>
</div>

<div class="rf-container" style="padding-bottom:48px;">

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        <div class="rf-flashes">
            {% for msg in messages %}
                <div class="rf-flash-item rf-flash-item--{{ label }}">{{ msg }}</div>
            {% endfor %}
        </div>
    {% endfor %}

    {# ── Bandeau statut + boutons d'action ── #}
    <div class="adm-action-bar">
        <span class="rf-badge rf-badge--{{ dossier.statut == 'brouillon' ? 'draft' : (dossier.statut == 'soumis' ? 'pending' : (dossier.statut == 'valide' ? 'ok' : 'refused')) }}"
              style="font-size:13px;padding:5px 14px;">
            {{ dossier.statutLabel }}
        </span>

        <div class="adm-action-bar__btns">

            {# Dossier soumis → valider ou refuser #}
            {% if dossier.statut == 'soumis' %}
                <form method="post"
                      action="{{ path('admin_dossier_statut', {id: dossier.id, statut: 'valide'}) }}"
                      onsubmit="return confirm('Valider ce dossier ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_statut_' ~ dossier.id) }}">
                    <button type="submit" class="rf-btn rf-btn--success">Valider</button>
                </form>
                <form method="post"
                      action="{{ path('admin_dossier_statut', {id: dossier.id, statut: 'refuse'}) }}"
                      onsubmit="return confirm('Refuser ce dossier ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_statut_' ~ dossier.id) }}">
                    <button type="submit" class="rf-btn rf-btn--danger">Refuser</button>
                </form>

            {# Dossier validé ou refusé → remettre en attente #}
            {% elseif dossier.statut in ['valide', 'refuse'] %}
                <form method="post"
                      action="{{ path('admin_dossier_statut', {id: dossier.id, statut: 'soumis'}) }}"
                      onsubmit="return confirm('Remettre ce dossier en attente ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_statut_' ~ dossier.id) }}">
                    <button type="submit" class="rf-btn rf-btn--secondary rf-btn--sm">
                        Remettre en attente
                    </button>
                </form>
            {% endif %}

        </div>
    </div>

    {# ── Layout 2 colonnes ── #}
    <div class="rf-layout-2col">

        {# ════════════════════════════════════════
           COLONNE PRINCIPALE
        ════════════════════════════════════════ #}
        <div>

            {# ── Informations personnelles (Étape 1) ── #}
            <div class="rf-card">
                <div class="rf-card__head">
                    <h2>Informations personnelles</h2>
                    <span class="adm-step-pill">Étape 1</span>
                </div>
                <div class="rf-card__body">
                    <dl class="rf-recap-dl">
                        <div>
                            <dt>Civilité</dt>
                            <dd>{{ dossier.genre == 'F' ? 'Madame' : (dossier.genre == 'M' ? 'Monsieur' : '—') }}</dd>
                        </div>
                        <div>
                            <dt>Nom / Prénom</dt>
                            {# ✅ dossier.nom peut être null → tester avant |upper #}
                            <dd>{{ dossier.nom ? dossier.nom|upper : '—' }} {{ dossier.prenom ?? '' }}</dd>
                        </div>
                        <div>
                            <dt>Date de naissance</dt>
                            <dd>{{ dossier.dateNaissance ? dossier.dateNaissance|date('d/m/Y') : '—' }}</dd>
                        </div>
                        <div>
                            <dt>Nationalité</dt>
                            <dd>{{ dossier.nationalite ?? '—' }}</dd>
                        </div>
                        <div>
                            <dt>Téléphone</dt>
                            <dd>{{ dossier.telephone ?? '—' }}</dd>
                        </div>
                        <div class="full">
                            <dt>Adresse</dt>
                            <dd>
                                {{ dossier.adresse ?? '—' }}
                                {% if dossier.codePostal or dossier.ville %}
                                    — {{ dossier.codePostal ?? '' }} {{ dossier.ville ?? '' }}
                                {% endif %}
                            </dd>
                        </div>
                    </dl>
                </div>
            </div>

            {# ── Parcours scolaire (Étape 2) ── #}
            <div class="rf-card">
                <div class="rf-card__head">
                    <h2>Parcours scolaire</h2>
                    <span class="adm-step-pill">Étape 2</span>
                </div>
                <div class="rf-card__body">
                    <dl class="rf-recap-dl">
                        <div>
                            <dt>Dernier diplôme</dt>
                            <dd>{{ dossier.dernierDiplome ?? '—' }}</dd>
                        </div>
                        <div>
                            <dt>Série / Spécialité</dt>
                            <dd>{{ dossier.specialiteBac ?? '—' }}</dd>
                        </div>
                        <div>
                            <dt>Mention</dt>
                            <dd>{{ dossier.mentionBac ?? '—' }}</dd>
                        </div>
                        <div>
                            <dt>Année d'obtention</dt>
                            <dd>{{ dossier.anneeObtention ?? '—' }}</dd>
                        </div>
                        <div class="full">
                            <dt>Établissement d'origine</dt>
                            <dd>{{ dossier.etablissementOrigine ?? '—' }}</dd>
                        </div>
                    </dl>

                    {% if dossier.experiencePro %}
                        <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--rf-gris-200);">
                            <p class="rf-section-title" style="margin-top:0;">Expérience professionnelle</p>
                            <p style="font-size:14px;white-space:pre-wrap;line-height:1.7;color:var(--rf-gris-800);margin:0;">
                                {{ dossier.experiencePro }}
                            </p>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# ── Choix BTS + lettre (Étape 3) ── #}
            <div class="rf-card">
                <div class="rf-card__head">
                    <h2>Choix du BTS</h2>
                    <span class="adm-step-pill">Étape 3</span>
                </div>
                <div class="rf-card__body">
                    <dl class="rf-recap-dl">
                        <div>
                            <dt>1er vœu</dt>
                            <dd><strong>{{ dossier.btsChoisi ?? '—' }}</strong></dd>
                        </div>
                        <div>
                            <dt>2e vœu</dt>
                            <dd>{{ dossier.btsChoisi2 ?? 'Aucun' }}</dd>
                        </div>
                        <div>
                            <dt>Apprentissage</dt>
                            {# ✅ getter isRegimeAppr() → Twig appelle dossier.regimeAppr #}
                            <dd>{{ dossier.regimeAppr ? 'Oui' : 'Non' }}</dd>
                        </div>
                    </dl>

                    {% if dossier.lettreMotivation %}
                        <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--rf-gris-200);">
                            <p class="rf-section-title" style="margin-top:0;">
                                Lettre de motivation
                                <span style="font-weight:400;color:var(--rf-gris-425);">
                                    ({{ dossier.lettreMotivation|length }} caractères)
                                </span>
                            </p>
                            <div class="adm-lettre">{{ dossier.lettreMotivation }}</div>
                        </div>
                    {% endif %}
                </div>
            </div>

        </div>

        {# ════════════════════════════════════════
           SIDEBAR
        ════════════════════════════════════════ #}
        <div style="display:flex;flex-direction:column;gap:16px;">

            {# ── Progression ── #}
            <div class="rf-card">
                <div class="rf-card__head"><h2>Avancement</h2></div>
                <div class="rf-card__body" style="padding:16px 20px;">
                    <div style="display:flex;justify-content:space-between;font-size:12.5px;margin-bottom:8px;">
                        <span style="color:var(--rf-gris-625);">Étape {{ dossier.etapeActuelle }} sur 5</span>
                        <strong style="color:var(--rf-bleu);">{{ dossier.progression }}&nbsp;%</strong>
                    </div>
                    <div class="rf-progress__track">
                        <div class="rf-progress__fill" style="width:{{ dossier.progression }}%"></div>
                    </div>
                </div>
            </div>

            {# ── Pièces justificatives (Étape 4) ── #}
            <div class="rf-card">
                <div class="rf-card__head">
                    <h2>Pièces justificatives</h2>
                    <span class="adm-step-pill">Étape 4</span>
                </div>
                <div class="rf-card__body" style="padding:0;">
                    {% if dossier.piecesJustificatives|length > 0 %}
                        {% for piece in dossier.piecesJustificatives %}
                        <div class="adm-piece-row">
                            <div>
                                <p class="adm-piece-row__type">{{ piece.typeLabel }}</p>
                                <p class="adm-piece-row__meta">
                                    {{ piece.nomFichier }}
                                    — {{ piece.tailleFormatee }}
                                    {# ✅ uploadedAt n'est pas dans l'entité Dossier mais dans PieceJustificative #}
                                    {% if piece.uploadedAt %}
                                        — {{ piece.uploadedAt|date('d/m/Y') }}
                                    {% endif %}
                                </p>
                            </div>
                            <a href="{{ path('admin_piece_download', {id: piece.id}) }}"
                               class="rf-btn rf-btn--secondary rf-btn--sm"
                               title="Télécharger {{ piece.typeLabel }}">
                                Télécharger
                            </a>
                        </div>
                        {% endfor %}
                    {% else %}
                        <p style="padding:20px;color:var(--rf-gris-425);font-size:13.5px;text-align:center;">
                            Aucune pièce déposée
                        </p>
                    {% endif %}
                </div>
            </div>

            {# ── Compte candidat ── #}
            <div class="rf-card">
                <div class="rf-card__head"><h2>Compte candidat</h2></div>
                <div class="rf-card__body" style="padding:16px 20px;">

                    <div class="rf-info-item">
                        <p class="rf-info-item__title">Adresse e-mail</p>
                        <p>{{ dossier.user.email }}</p>
                    </div>

                    <div class="rf-info-item">
                        <p class="rf-info-item__title">Vérification e-mail</p>
                        {# ✅ getter isVerified() → Twig appelle dossier.user.verified #}
                        <p>
                            {% if dossier.user.verified %}
                                <span class="rf-account-pill">
                                    <span class="rf-account-pill__dot rf-account-pill__dot--ok"></span>
                                    Adresse vérifiée
                                </span>
                            {% else %}
                                <span class="rf-account-pill">
                                    <span class="rf-account-pill__dot rf-account-pill__dot--warning"></span>
                                    Non vérifiée
                                </span>
                            {% endif %}
                        </p>
                    </div>

                    <div class="rf-info-item">
                        <p class="rf-info-item__title">Dernière modification</p>
                        {# ✅ createdAt n'a pas de getter public → on utilise updatedAt #}
                        <p>{{ dossier.updatedAt|date('d/m/Y à H:i') }}</p>
                    </div>

                    {% if dossier.soumisAt %}
                    <div class="rf-info-item">
                        <p class="rf-info-item__title">Date de soumission</p>
                        <p>{{ dossier.soumisAt|date('d/m/Y à H:i') }}</p>
                    </div>
                    {% endif %}

                </div>
            </div>

        </div>
    </div>

    {# ── Pied de page ── #}
    <div style="margin-top:16px;">
        <a href="{{ path('admin_candidats') }}" class="rf-btn rf-btn--secondary">
            ← Retour à la liste
        </a>
    </div>

</div>

<style>
/* ── Barre d'action statut ─────────────────────────────────────────────────── */
.adm-action-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 24px;
    padding: 14px 16px;
    background: var(--rf-blanc);
    border: 1px solid var(--rf-gris-200);
    border-radius: var(--rf-radius);
}
.adm-action-bar__btns {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}

/* ── Pill étape ────────────────────────────────────────────────────────────── */
.adm-step-pill {
    font-size: 11px;
    font-weight: 700;
    color: var(--rf-gris-425);
    background: var(--rf-gris-100);
    border: 1px solid var(--rf-gris-200);
    border-radius: 20px;
    padding: 2px 10px;
    letter-spacing: .04em;
}

/* ── Pièce justificative ───────────────────────────────────────────────────── */
.adm-piece-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--rf-gris-200);
}
.adm-piece-row:last-child { border-bottom: none; }
.adm-piece-row__type { font-size: 13px; font-weight: 700; color: var(--rf-gris-900); margin: 0 0 3px; }
.adm-piece-row__meta { font-size: 11.5px; color: var(--rf-gris-425); margin: 0; line-height: 1.6; }

/* ── Lettre de motivation ──────────────────────────────────────────────────── */
.adm-lettre {
    font-size: 13.5px;
    white-space: pre-wrap;
    line-height: 1.8;
    color: var(--rf-gris-800);
    background: var(--rf-gris-50);
    border-left: 3px solid var(--rf-bleu-border);
    border-radius: 0 var(--rf-radius) var(--rf-radius) 0;
    padding: 14px 16px;
}

/* ── Bouton danger ─────────────────────────────────────────────────────────── */
.rf-btn--danger {
    background: #c0000a;
    color: #fff;
    border-color: #c0000a;
}
.rf-btn--danger:hover { background: #8b0007; border-color: #8b0007; color: #fff; }
</style>

{% endblock %}
