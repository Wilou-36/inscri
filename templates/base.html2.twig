{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr" data-fr-scheme="system">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Inscription BTS — Lycée Fulbert, Académie d'Orléans-Tours">

    {# DSFR — Système de Design de l'État (CDN officiel) #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@gouvfr/dsfr@1.12.1/dist/dsfr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@gouvfr/dsfr@1.12.1/dist/utility/utility.min.css">

    <title>{% block title %}Inscriptions BTS{% endblock %} — Lycée Fulbert</title>
    {% block stylesheets %}{% endblock %}
</head>
<body>

{# ═══════════════════════════════════════════════════════════════════
   EN-TÊTE — Conforme DSFR / Charte de l'État
   ═══════════════════════════════════════════════════════════════════ #}
<header role="banner" class="fr-header">
    <div class="fr-header__body">
        <div class="fr-container">
            <div class="fr-header__body-row">

                <div class="fr-header__brand fr-enlarge-link">
                    <div class="fr-header__brand-top">

                        {# Logo République Française #}
                        <div class="fr-header__logo">
                            <p class="fr-logo">
                                République<br>Française
                            </p>
                        </div>

                        {# Opérateur ministériel #}
                        <div class="fr-header__operator">
                            <p class="fr-text--sm" style="margin:0;line-height:1.3;">
                                Ministère de<br>
                                <strong>l'Éducation nationale</strong><br>
                                <span class="fr-text--xs">Académie d'Orléans-Tours</span>
                            </p>
                        </div>

                        {# Bouton menu mobile #}
                        <button class="fr-btn--menu fr-btn"
                                data-fr-opened="false"
                                aria-controls="header-nav"
                                aria-haspopup="menu"
                                id="header-btn-menu"
                                title="Menu">
                            Menu
                        </button>
                    </div>

                    <div class="fr-header__service">
                        <a href="{{ path('app_dashboard') }}"
                           title="Accueil — Inscriptions BTS Lycée Fulbert">
                            <p class="fr-header__service-title">Inscriptions BTS</p>
                        </a>
                        <p class="fr-header__service-tagline">
                            Lycée Fulbert — Chartres (28) — Dépôt de dossier en ligne
                        </p>
                    </div>
                </div>

                <div class="fr-header__tools">
                    <div class="fr-header__tools-links">
                        <ul class="fr-btns-group">
                            {% if app.user %}
                                <li>
                                    <a class="fr-btn fr-btn--sm fr-icon-account-circle-line fr-btn--icon-left"
                                       href="{{ path('app_dashboard') }}">
                                        Mon espace
                                    </a>
                                </li>
                                <li>
                                    <a class="fr-btn fr-btn--sm fr-btn--tertiary-no-outline"
                                       href="{{ path('app_logout') }}">
                                        Déconnexion
                                    </a>
                                </li>
                            {% else %}
                                <li>
                                    <a class="fr-btn fr-btn--sm fr-icon-account-circle-line fr-btn--icon-left"
                                       href="{{ path('app_login') }}">
                                        Se connecter
                                    </a>
                                </li>
                                <li>
                                    <a class="fr-btn fr-btn--sm fr-btn--secondary"
                                       href="{{ path('app_register') }}">
                                        Créer un compte
                                    </a>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </div>

    {# Menu principal — responsive #}
    <div class="fr-header__menu fr-modal"
         id="header-nav"
         aria-labelledby="header-btn-menu">
        <div class="fr-container">
            <button class="fr-link--close fr-link"
                    aria-controls="header-nav">Fermer</button>
            <div class="fr-header__menu-links"></div>
            <nav class="fr-nav" id="navigation-main"
                 role="navigation" aria-label="Menu principal">
                <ul class="fr-nav__list">

                    <li class="fr-nav__item">
                        <a class="fr-nav__link"
                           href="{{ path('app_dashboard') }}"
                           {% if app.request.attributes.get('_route') == 'app_dashboard' %}aria-current="page"{% endif %}>
                            Tableau de bord
                        </a>
                    </li>

                    {% if app.user %}
                        <li class="fr-nav__item">
                            <a class="fr-nav__link"
                               href="{{ path('inscription_step1') }}"
                               {% if app.request.attributes.get('_route') starts with 'inscription' %}aria-current="page"{% endif %}>
                                Mon dossier
                            </a>
                        </li>
                    {% endif %}

                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="fr-nav__item">
                            <a class="fr-nav__link"
                               href="{{ path('admin_dashboard') }}"
                               {% if app.request.attributes.get('_route') starts with 'admin' %}aria-current="page"{% endif %}>
                                Administration
                            </a>
                        </li>
                    {% endif %}

                </ul>
            </nav>
        </div>
    </div>
</header>

{# ═══════════════════════════════════════════════════════════════════
   CONTENU
   ═══════════════════════════════════════════════════════════════════ #}

{% block breadcrumb %}{% endblock %}

{# Alertes flash DSFR #}
{% for type, messages in app.flashes %}
    {% set dsfrType = type == 'danger' ? 'error' : type %}
    {% for message in messages %}
        <div class="fr-container fr-mt-2w">
            <div class="fr-alert fr-alert--{{ dsfrType }} fr-alert--sm">
                <p>{{ message }}</p>
            </div>
        </div>
    {% endfor %}
{% endfor %}

<main role="main" id="content" tabindex="-1">
    {% block body %}{% endblock %}
</main>

{# ═══════════════════════════════════════════════════════════════════
   PIED DE PAGE — Conforme DSFR
   ═══════════════════════════════════════════════════════════════════ #}
<footer class="fr-footer" role="contentinfo" id="footer">
    <div class="fr-container">
        <div class="fr-footer__body">

            <div class="fr-footer__brand fr-enlarge-link">
                <a href="/" title="Retour à l'accueil — Lycée Fulbert">
                    <p class="fr-logo">
                        République<br>Française
                    </p>
                </a>
            </div>

            <div class="fr-footer__content">
                <p class="fr-footer__content-desc">
                    <strong>Lycée Fulbert</strong><br>
                    14 Cloître Notre-Dame, 28000 Chartres<br>
                    Rectorat de l'Académie d'Orléans-Tours
                </p>
                <ul class="fr-footer__content-list">
                    <li class="fr-footer__content-item">
                        <a class="fr-footer__content-link"
                           href="https://www.education.gouv.fr"
                           target="_blank" rel="noopener noreferrer">
                            education.gouv.fr
                        </a>
                    </li>
                    <li class="fr-footer__content-item">
                        <a class="fr-footer__content-link"
                           href="https://www.ac-orleans-tours.fr"
                           target="_blank" rel="noopener noreferrer">
                            ac-orleans-tours.fr
                        </a>
                    </li>
                    <li class="fr-footer__content-item">
                        <a class="fr-footer__content-link"
                           href="https://www.service-public.fr"
                           target="_blank" rel="noopener noreferrer">
                            service-public.fr
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="fr-footer__bottom">
            <ul class="fr-footer__bottom-list">
                <li class="fr-footer__bottom-item">
                    <a class="fr-footer__bottom-link" href="#">
                        Accessibilité : non conforme
                    </a>
                </li>
                <li class="fr-footer__bottom-item">
                    <a class="fr-footer__bottom-link" href="#">Mentions légales</a>
                </li>
                <li class="fr-footer__bottom-item">
                    <a class="fr-footer__bottom-link" href="#">
                        Données personnelles et cookies
                    </a>
                </li>
                <li class="fr-footer__bottom-item">
                    <a class="fr-footer__bottom-link" href="#">Contact</a>
                </li>
            </ul>
            <div class="fr-footer__bottom-copy">
                <p>
                    Contenu soumis à
                    <a href="https://github.com/etalab/licence-ouverte/blob/master/LO.md"
                       target="_blank" rel="noopener noreferrer">
                        licence etalab-2.0
                    </a>
                    — {{ "now"|date("Y") }}
                </p>
            </div>
        </div>
    </div>
</footer>

{# DSFR JS — obligatoire #}
<script type="module"
        src="https://cdn.jsdelivr.net/npm/@gouvfr/dsfr@1.12.1/dist/dsfr.module.min.js">
</script>
<script type="text/javascript" nomodule
        src="https://cdn.jsdelivr.net/npm/@gouvfr/dsfr@1.12.1/dist/dsfr.nomodule.min.js">
</script>

{% block javascripts %}{% endblock %}
</body>
</html>
